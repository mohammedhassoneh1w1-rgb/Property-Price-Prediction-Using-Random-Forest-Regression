        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error, mean_absolute_percentage_error\n",
        "import matplotlib.pyplot as plt\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# Load data\n",
        "df = pd.read_excel('/content/Ames housing data.xlsx')\n",
        "\n",
        "print(\"=\" * 80)\n",
        "print(\"RANDOM FOREST MODEL FOR AMES HOUSING PRICE PREDICTION\")\n",
        "print(\"=\" * 80)\n",
        "print(f\"\\nDataset: {len(df)} properties\")\n",
        "print(f\"Total Features: {len(df.columns)}\")\n",
        "\n",
        "# Separate numeric and categorical features\n",
        "numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
        "categorical_cols = df.select_dtypes(include=['object']).columns.tolist()\n",
        "\n",
        "print(f\"Numeric Features: {len(numeric_cols)}\")\n",
        "print(f\"Categorical Features: {len(categorical_cols)}\")\n",
        "\n",
        "# Remove ID and target variable from features\n",
        "if 'ID' in numeric_cols:\n",
        "    numeric_cols.remove('ID')\n",
        "if 'Sale Price' in numeric_cols:\n",
        "    numeric_cols.remove('Sale Price')\n",
        "\n",
        "# Create a copy for preprocessing\n",
        "X = df[numeric_cols + categorical_cols].copy()\n",
        "y = df['Sale Price'].copy()\n",
        "\n",
        "# Handle missing values\n",
        "print(f\"\\nHandling missing values...\")\n",
        "for col in numeric_cols:\n",
        "    if X[col].isnull().sum() > 0:\n",
        "        X[col].fillna(X[col].median(), inplace=True)\n",
        "\n",
        "# Encode categorical variables\n",
        "label_encoders = {}\n",
        "for col in categorical_cols:\n",
        "    if col in X.columns:\n",
        "        X[col].fillna('Unknown', inplace=True)\n",
        "        le = LabelEncoder()\n",
        "        X[col] = le.fit_transform(X[col].astype(str))\n",
        "        label_encoders[col] = le\n",
        "\n",
        "print(f\"\\nPrice Statistics:\")\n",
        "print(f\"  Minimum: ${y.min():,.0f}\")\n",
        "print(f\"  Maximum: ${y.max():,.0f}\")\n",
        "print(f\"  Average: ${y.mean():,.0f}\")\n",
        "print(f\"  Median: ${y.median():,.0f}\")\n",
        "print(f\"  Std Dev: ${y.std():,.0f}\")\n",
        "\n",
        "# Remove outliers (prices > 3 std dev from mean)\n",
        "mean_price = y.mean()\n",
        "std_price = y.std()\n",
        "upper_bound = mean_price + 3 * std_price\n",
        "X_clean = X[y <= upper_bound].copy()\n",
        "y_clean = y[y <= upper_bound].copy()\n",
        "\n",
        "print(f\"\\nOutlier Removal:\")\n",
        "print(f\"  Properties removed: {len(df) - len(X_clean)}\")\n",
        "print(f\"  Properties remaining: {len(X_clean)}\")\n",
        "\n",
        "# Split data\n",
        "X_train, X_test, y_train, y_test = train_test_split(X_clean, y_clean, test_size=0.2, random_state=42)\n",
        "\n",
        "print(f\"\\nData Split:\")\n",
        "print(f\"  Training set: {len(X_train)} properties\")\n",
        "print(f\"  Test set: {len(X_test)} properties\")\n",
        "\n",
        "# Train Random Forest\n",
        "print(f\"\\nTraining Random Forest (200 trees)...\")\n",
        "rf_model = RandomForestRegressor(\n",
        "    n_estimators=200,\n",
        "    max_depth=25,\n",
        "    min_samples_split=10,\n",
        "    min_samples_leaf=5,\n",
        "    max_features='sqrt',\n",
        "    random_state=42,\n",
        "    n_jobs=-1,\n",
        "    verbose=0\n",
        ")\n",
        "\n",
        "rf_model.fit(X_train, y_train)\n",
        "print(\"✓ Model trained successfully!\")\n",
        "\n",
        "# Make predictions\n",
        "y_train_pred = rf_model.predict(X_train)\n",
        "y_test_pred = rf_model.predict(X_test)\n",
        "\n",
        "# Evaluate model\n",
        "print(\"\\n\" + \"=\" * 80)\n",
        "print(\"MODEL PERFORMANCE METRICS\")\n",
        "print(\"=\" * 80)\n",
        "\n",
        "train_r2 = r2_score(y_train, y_train_pred)\n",
        "test_r2 = r2_score(y_test, y_test_pred)\n",
        "test_rmse = np.sqrt(mean_squared_error(y_test, y_test_pred))\n",
        "test_mae = mean_absolute_error(y_test, y_test_pred)\n",
        "test_mape = mean_absolute_percentage_error(y_test, y_test_pred)\n",
        "\n",
        "print(f\"\\nR² Score:\")\n",
        "print(f\"  Train R²: {train_r2:.4f} (explains {train_r2*100:.2f}% of variance)\")\n",
        "print(f\"  Test R²:  {test_r2:.4f} (explains {test_r2*100:.2f}% of variance)\")\n",
        "\n",
        "print(f\"\\nError Metrics:\")\n",
        "print(f\"  RMSE (Test): ${test_rmse:,.0f}\")\n",
        "print(f\"  MAE (Test):  ${test_mae:,.0f}\")\n",
        "print(f\"  MAPE (Test): {test_mape*100:.2f}%\")\n",
        "\n",
        "# Feature importance\n",
        "feature_importance = pd.DataFrame({\n",
        "    'Feature': X_clean.columns,\n",
        "    'Importance': rf_model.feature_importances_\n",
        "}).sort_values('Importance', ascending=False)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 80)\n",
        "print(\"TOP 15 MOST IMPORTANT FEATURES\")\n",
        "print(\"=\" * 80)\n",
        "for idx, row in feature_importance.head(15).iterrows():\n",
        "    print(f\"{row['Feature']:30s} {row['Importance']:7.4f} ({row['Importance']*100:5.2f}%)\")\n",
        "\n",
        "# Visualization 1: Top 15 Feature Importance\n",
        "plt.figure(figsize=(12, 7))\n",
        "top_features = feature_importance.head(15)\n",
        "colors = plt.cm.Spectral(np.linspace(0.2, 0.8, len(top_features)))\n",
        "bars = plt.barh(range(len(top_features)), top_features['Importance'], color=colors)\n",
        "plt.yticks(range(len(top_features)), top_features['Feature'])\n",
        "plt.xlabel('Importance Score', fontsize=12, fontweight='bold')\n",
        "plt.title('Top 15 Most Important Features - Ames Housing Model', fontsize=13, fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.savefig('/mnt/user-data/outputs/ames_feature_importance.png', dpi=300, bbox_inches='tight')\n",
        "print(\"\\n✓ Saved: ames_feature_importance.png\")\n",
        "\n",
        "# Visualization 2: Actual vs Predicted\n",
        "plt.figure(figsize=(12, 8))\n",
        "plt.scatter(y_test, y_test_pred, alpha=0.5, s=40, color='steelblue', edgecolors='navy', linewidth=0.3)\n",
        "min_val = min(y_test.min(), y_test_pred.min())\n",
        "max_val = max(y_test.max(), y_test_pred.max())\n",
        "plt.plot([min_val, max_val], [min_val, max_val], 'r--', lw=2.5, label='Perfect Prediction')\n",
        "plt.xlabel('Actual Price ($)', fontsize=12, fontweight='bold')\n",
        "plt.ylabel('Predicted Price ($)', fontsize=12, fontweight='bold')\n",
        "plt.title(f'Actual vs Predicted Prices (R² = {test_r2:.4f})', fontsize=13, fontweight='bold')\n",
        "plt.legend(fontsize=11)\n",
        "plt.ticklabel_format(style='plain', axis='both')\n",
        "plt.tight_layout()\n",
        "plt.savefig('/mnt/user-data/outputs/ames_actual_vs_predicted.png', dpi=300, bbox_inches='tight')\n",
        "print(\"✓ Saved: ames_actual_vs_predicted.png\")\n",
        "\n",
        "# Visualization 3: Residuals\n",
        "plt.figure(figsize=(12, 6))\n",
        "residuals = y_test - y_test_pred\n",
        "plt.scatter(y_test_pred, residuals, alpha=0.5, s=40, color='steelblue', edgecolors='navy', linewidth=0.3)\n",
        "plt.axhline(y=0, color='r', linestyle='--', lw=2.5)\n",
        "plt.xlabel('Predicted Price ($)', fontsize=12, fontweight='bold')\n",
        "plt.ylabel('Residuals ($)', fontsize=12, fontweight='bold')\n",
        "plt.title('Residuals Plot - Ames Housing Model', fontsize=13, fontweight='bold')\n",
        "plt.ticklabel_format(style='plain', axis='x')\n",
        "plt.tight_layout()\n",
        "plt.savefig('/mnt/user-data/outputs/ames_residuals_plot.png', dpi=300, bbox_inches='tight')\n",
        "print(\"✓ Saved: ames_residuals_plot.png\")\n",
        "\n",
        "\n",
        "\n",
        "# Sample predictions\n",
        "print(\"\\n\" + \"=\" * 80)\n",
        "print(\"SAMPLE PREDICTIONS ON TEST SET\")\n",
        "print(\"=\" * 80)\n",
